<% content_for :title, "Usuarios" %>

<div class="max-w-7xl mx-auto space-y-6">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-stone-900 tracking-tight pb-1">Gestión de Usuarios</h1>
      <p class="mt-1 text-sm text-stone-500">Administra los roles y accesos al sistema.</p>
    </div>
  </div>

  <% if notice %>
    <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-4 shadow-sm">
      <div class="flex items-center gap-3">
        <svg class="h-5 w-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <p class="text-sm font-semibold text-emerald-800"><%= notice %></p>
      </div>
    </div>
  <% elsif alert %>
    <div class="rounded-xl border border-red-200 bg-red-50 p-4 shadow-sm">
      <div class="flex items-center gap-3">
        <svg class="h-5 w-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
        <p class="text-sm font-semibold text-red-800"><%= alert %></p>
      </div>
    </div>
  <% end %>

  <!-- Tabla de Usuarios -->
  <div class="bg-white rounded-2xl shadow-sm border border-stone-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-stone-50 text-stone-500 text-xs uppercase tracking-wider">
            <th class="px-6 py-4 font-bold border-b border-stone-200">Email</th>
            <th class="px-6 py-4 font-bold border-b border-stone-200 text-center">Rol Actual</th>
            <th class="px-6 py-4 font-bold border-b border-stone-200 text-right">Cambiar Rol</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-100">
          <% @usuarios.each do |usuario| %>
            <tr class="hover:bg-stone-50 transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-stone-200 flex items-center justify-center text-xs font-bold text-stone-600">
                    <%= usuario.username[0].upcase %>
                  </div>
                  <span class="text-sm font-semibold text-stone-900"><%= usuario.username %></span>
                </div>
              </td>
              
              <td class="px-6 py-4 text-center">
                <% case usuario.role %>
                <% when "admin" %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-red-100 text-red-800 ring-1 ring-red-600/20">Admin</span>
                <% when "encargado" %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-amber-100 text-amber-800 ring-1 ring-amber-600/20">Encargado</span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-stone-100 text-stone-700 ring-1 ring-stone-500/10">Bombero</span>
                <% end %>
              </td>

              <td class="px-6 py-4 text-right">
                <% if usuario == current_user %>
                  <span class="text-sm text-stone-400 italic px-2">No puedes modificarte a ti mismo</span>
                <% else %>
                  <%= form_with(model: usuario, url: usuario_path(usuario), method: :patch, local: true, class: "flex items-center justify-end gap-2") do |f| %>
                    <%= f.select :role, User.roles.keys.map { |r| [r.humanize, r] },
                                 {}, class: "block w-32 rounded-lg border-stone-200 shadow-sm focus:border-red-500 focus:ring-red-500 text-sm py-1.5 pl-3 pr-8 bg-white text-stone-700" %>
                    <%= f.submit "Actualizar", class: "px-3 py-1.5 bg-white hover:bg-red-50 border border-stone-200 hover:border-red-200 text-red-600 text-sm font-semibold rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-1 cursor-pointer" %>
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

</div>
