 *
 * You're free to add application-wide styles to this file and they'll appear at the bottom of the
 * compiled file so the styles you add here take precedence over styles defined in any other CSS
 * files in this directory. Styles in this file should be added after the last require_* statement.
 * It is generally better to create a new file per style scope.
 *
 *= require_tree .
 *= require_self
 */
thead {
  --bs-table-bg: #ffc107 !important;
  background-color: var(--bs-table-bg) !important;
  color: black !important;
  text-align: center;
}

thead th {
  vertical-align: middle;
  text-align: center;
}
.table-entrada {
  background-color: #4ef775 !important; /* verde claro */
}

/* Burbuja de productos */
.navbar .nav-item .badge {
  font-size: 0.65rem;
  padding: 0.35em 0.5em;
  cursor: pointer;
}

/* Separador entre botones */
.navbar-nav .nav-item + .nav-item {
  border-left: 1px solid rgba(255, 255, 255, 0.3);
  padding-left: 0.75rem;
  margin-left: 0.75rem;
}

/* Sidebar móvil */
@media (max-width: 768px) {
  #sidebar {
    position: absolute;
    left: -240px;
    top: 0;
    height: 100%;
    z-index: 1050;
    transition: left 0.3s ease;
  }

  #sidebar.active {
    left: 0;
  }
}


#sidebar .nav-link:hover {
  background: #dc3545;
  border-radius: 6px;
}

/* Fondo del login */
.login-bg {
  position: relative;
  width: 100%;
  height: 100vh;

  background-image: url("<%= asset_path('firetruck.jpg') %>");

  background-size: cover !important;
  background-position: center !important;
  background-repeat: no-repeat !important;

  display: flex;
  justify-content: center;
  align-items: center;
}

/* Capa de oscurecimiento */
.login-bg::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.45); /* Oscurecimiento */
  backdrop-filter: blur(2px);     /* Suaviza la imagen detrás */
  z-index: 1;
}


.login-card {
  position: relative;
  z-index: 2;

  background: rgba(255, 255, 255, 0.90);
  backdrop-filter: blur(8px);
  padding: 2rem 3rem;
  border-radius: 14px;

  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.25);
  max-width: 420px;
  width: 100%;
  animation: fadeIn 0.6s ease-out;
}

/* Animación suave de aparición */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}







