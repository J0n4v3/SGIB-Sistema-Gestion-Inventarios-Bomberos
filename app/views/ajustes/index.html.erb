<% content_for :title, "Ajustes de Inventario" %>

<div class="max-w-7xl mx-auto space-y-6">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-stone-900 tracking-tight pb-1">Historial de Ajustes</h1>
      <p class="mt-1 text-sm text-stone-500">Registro de correcciones manuales de stock.</p>
    </div>
    
    <div>
      <%= link_to new_ajuste_path, class: "inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-red-700 hover:bg-red-800 text-white text-sm font-semibold rounded-xl shadow-sm shadow-red-700/20 transition-all focus:outline-none focus:ring-2 focus:ring-red-600 focus:ring-offset-2" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Nuevo Ajuste
      <% end %>
    </div>
  </div>

  <!-- Tabla de Ajustes -->
  <div class="bg-white rounded-2xl shadow-sm border border-stone-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-stone-50 text-stone-500 text-xs uppercase tracking-wider">
            <th class="px-6 py-4 font-bold border-b border-stone-200">Fecha</th>
            <th class="px-6 py-4 font-bold border-b border-stone-200">Producto</th>
            <th class="px-6 py-4 font-bold border-b border-stone-200 text-center">Anterior</th>
            <th class="px-6 py-4 font-bold border-b border-stone-200 text-center">Nuevo</th>
            <th class="px-6 py-4 font-bold border-b border-stone-200">Motivo</th>
            <th class="px-6 py-4 font-bold border-b border-stone-200">Usuario</th>
            
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-100">
          <% @ajustes.each do |ajuste| %>
            <tr class="hover:bg-stone-50 transition-colors">
            <td class="px-6 py-4 text-sm text-stone-500 font-mono">
                <%= ajuste.created_at.strftime("%d/%m/%Y %H:%M") %>
              </td>
              <td class="px-6 py-4 text-sm font-semibold text-stone-900"><%= ajuste.producto.nombre %></td>
              <td class="px-6 py-4 text-center">
                <span class="inline-flex items-center justify-center min-w-[2rem] px-2 py-0.5 rounded text-sm font-medium bg-stone-100 text-stone-600">
                  <%= ajuste.cantidad_anterior %>
                </span>
              </td>
              <td class="px-6 py-4 text-center">
                <span class="inline-flex items-center justify-center min-w-[2rem] px-2 py-0.5 rounded text-sm font-bold bg-amber-100 text-amber-800 ring-1 ring-amber-200">
                  <%= ajuste.cantidad_nueva %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-stone-600 truncate max-w-[200px]" title="<%= ajuste.motivo %>">
                <%= ajuste.motivo %>
              </td>
              <td class="px-6 py-4 text-sm text-stone-500">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded-full bg-stone-200 flex items-center justify-center text-[10px] font-bold text-stone-600">
                    <%= ajuste.user.username[0].upcase %>
                  </div>
                  <%= ajuste.user.username.split('@').first %>
                </div>
              </td>
              
            </tr>
          <% end %>
          <% if @ajustes.empty? %>
            <tr>
              <td colspan="6" class="px-6 py-12 text-center text-stone-500 text-sm">
                <div class="flex flex-col items-center justify-center">
                  <svg class="w-10 h-10 text-stone-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                  <p class="text-base font-medium text-stone-900">No hay ajustes</p>
                  <p class="mt-1">Aún no se ha registrado ningún ajuste manual de inventario.</p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

</div>
