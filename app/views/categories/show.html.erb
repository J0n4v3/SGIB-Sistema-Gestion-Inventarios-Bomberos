<% content_for :title, "Categoría" %>

<div class="max-w-4xl mx-auto space-y-6">
  
  <% if notice %>
    <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-4 shadow-sm">
      <div class="flex items-center gap-3">
        <svg class="h-5 w-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <p class="text-sm font-semibold text-emerald-800"><%= notice %></p>
      </div>
    </div>
  <% elsif alert %>
    <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 shadow-sm">
      <div class="flex items-center gap-3">
        <svg class="h-5 w-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
        <p class="text-sm font-semibold text-amber-800"><%= alert %></p>
      </div>
    </div>
  <% end %>

  <!-- Header & Acciones -->
  <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
    <div class="flex items-start gap-4">
      <%= link_to categories_path, class: "p-2 text-stone-400 hover:text-stone-600 bg-white border border-stone-200 rounded-xl hover:bg-stone-50 transition-colors mt-1" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      <% end %>
      <div>
        <h1 class="text-3xl font-bold text-stone-900 tracking-tight mb-1"><%= @category.nombre %></h1>
        <p class="text-sm text-stone-500 font-mono">ID: <%= @category.id %></p>
      </div>
    </div>

    <div class="flex items-center gap-2">
      <%= link_to edit_category_path(@category), class: "inline-flex items-center justify-center gap-2 px-4 py-2 bg-amber-50 hover:bg-amber-100 border border-amber-200 text-amber-700 text-sm font-semibold rounded-xl transition-colors focus:outline-none focus:ring-2 focus:ring-amber-500 focus:ring-offset-2" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
        Editar
      <% end %>

      <% if @category.productos.empty? %>
        <%= link_to category_path(@category), data: { turbo_method: :delete, turbo_confirm: "¿Estás seguro que querés eliminar esta categoría?" }, class: "inline-flex items-center justify-center gap-2 px-4 py-2 bg-white hover:bg-red-50 border border-stone-200 hover:border-red-200 text-red-600 text-sm font-semibold rounded-xl transition-colors focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
          Eliminar
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Detalles -->
    <div class="md:col-span-1 bg-white rounded-2xl shadow-sm border border-stone-200 overflow-hidden h-fit">
      <div class="px-6 py-5 border-b border-stone-100 bg-stone-50/50">
        <h3 class="text-base font-semibold text-stone-900">Información General</h3>
      </div>
      <div class="px-6 py-5 space-y-4">
        <div>
          <h4 class="text-sm font-medium text-stone-500">Descripción</h4>
          <p class="mt-1 text-sm text-stone-900"><%= @category.descripcion.presence || "No especificada." %></p>
        </div>
        <div class="pt-4 border-t border-stone-100">
          <h4 class="text-sm font-medium text-stone-500">Total Productos</h4>
          <p class="mt-1 text-2xl font-bold text-stone-900"><%= @category.productos.count %></p>
        </div>
      </div>
    </div>

    <!-- Lista de Productos -->
    <div class="md:col-span-2 bg-white rounded-2xl shadow-sm border border-stone-200 overflow-hidden">
      <div class="px-6 py-5 border-b border-stone-100 bg-stone-50/50 flex items-center justify-between">
        <h3 class="text-base font-semibold text-stone-900">Productos en esta categoría</h3>
      </div>
      
      <% if @category.productos.any? %>
        <ul class="divide-y divide-stone-100">
          <% @category.productos.each do |producto| %>
            <li class="px-6 py-4 hover:bg-stone-50 transition-colors flex items-center justify-between">
              <%= link_to producto.nombre, producto_path(producto), class: "text-sm font-semibold text-stone-900 hover:text-red-700 transition-colors" %>
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-stone-100 text-stone-700 ring-1 ring-inset ring-stone-500/10">
                  <%= producto.cantidad %> <%= producto.unidad %>
                </span>
                <%= link_to "Ver", producto_path(producto), class: "text-xs font-medium text-stone-500 hover:text-stone-900" %>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="px-6 py-8 text-center text-stone-500 text-sm">
          No hay productos asociados a esta categoría.
        </div>
      <% end %>
    </div>
  </div>

</div>
