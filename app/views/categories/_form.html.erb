<%= form_with(model: category, local: true, class: "space-y-6") do |f| %>
  <% if category.errors.any? %>
    <div class="rounded-xl border border-red-200 bg-red-50 p-4 shadow-sm mb-6">
      <h4 class="text-sm font-bold text-red-800"><%= pluralize(category.errors.count, "error") %> impide guardar esta categoría:</h4>
      <ul class="mt-2 list-disc list-inside text-sm text-red-700">
        <% category.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-2xl shadow-sm border border-stone-200 p-6 md:p-8">
    <div class="space-y-6">
      <div>
        <%= f.label :nombre, "Nombre", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.text_field :nombre, class: "block w-full rounded-xl border border-stone-300 shadow-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/50 sm:text-sm px-4 py-2.5 bg-white text-stone-900 transition-colors" %>
      </div>

      <div>
        <%= f.label :descripcion, "Descripción", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.text_area :descripcion, rows: 3, class: "block w-full rounded-xl border border-stone-300 shadow-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/50 sm:text-sm px-4 py-2.5 bg-white text-stone-900 transition-colors" %>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3 pt-2">
    <%= link_to "Cancelar", categories_path, class: "px-4 py-2.5 text-sm font-medium text-stone-600 bg-white border  border-stone-200 rounded-xl hover:bg-stone-50 hover:text-stone-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-stone-500 transition-colors" %>
    <button type="button" onclick="document.getElementById('modal-guardar-categoria').classList.remove('hidden')" class="px-6 py-2.5 bg-red-700 hover:bg-red-800 text-white text-sm font-semibold rounded-xl shadow-sm shadow-red-700/20 focus:outline-none focus:ring-2 focus:ring-red-600 focus:ring-offset-2 transition-all cursor-pointer">Guardar Categoría</button>
  </div>

  <!-- Modal de confirmación para guardar -->
  <div id="modal-guardar-categoria" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" style="margin-top: 0px;">
    <div class="absolute inset-0 bg-stone-900/50 backdrop-blur-sm"
         onclick="document.getElementById('modal-guardar-categoria').classList.add('hidden')"></div>
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-sm p-6 space-y-4">
      <h2 class="text-lg font-bold text-stone-900">¿Guardar categoría?</h2>
      <p class="text-sm text-stone-500">Confirma que deseas guardar la información de esta categoría.</p>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button"
                onclick="document.getElementById('modal-guardar-categoria').classList.add('hidden')"
                class="px-4 py-2 text-sm font-semibold text-stone-700 bg-white border border-stone-200 rounded-xl hover:bg-stone-50">
          Cancelar
        </button>
        <%= f.submit "Confirmar", class: "px-4 py-2 text-sm font-semibold text-white bg-red-600 hover:bg-red-700 rounded-xl cursor-pointer" %>
      </div>
    </div>
  </div>
<% end %>
