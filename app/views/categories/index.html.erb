<% content_for :title, "Categorías" %>

<div class="max-w-7xl mx-auto space-y-6">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-stone-900 tracking-tight pb-1">Listado de Categorías</h1>
      <p class="mt-1 text-sm text-stone-500">Administra las clasificaciones de los productos.</p>
    </div>
    
    <div>
      <%= link_to new_category_path, class: "inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-red-700 hover:bg-red-800 text-white text-sm font-semibold rounded-xl shadow-sm shadow-red-700/20 transition-all focus:outline-none focus:ring-2 focus:ring-red-600 focus:ring-offset-2" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Nueva Categoría
      <% end %>
    </div>
  </div>



  <!-- Tabla de Categorías -->
  <div class="bg-white rounded-2xl shadow-sm border border-stone-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-stone-50 text-stone-500 text-xs uppercase tracking-wider">
            <th class="px-6 py-4 font-medium border-b border-stone-200 w-16">ID</th>
            <th class="px-6 py-4 font-medium border-b border-stone-200">Nombre</th>
            <th class="px-6 py-4 font-medium border-b border-stone-200">Descripción</th>
            <th class="px-6 py-4 font-medium border-b border-stone-200 text-center">Productos</th>
            <th class="px-6 py-4 font-medium border-b border-stone-200 text-right">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-100">
          <% @categories.each do |category| %>
            <tr class="hover:bg-stone-50 transition-colors">
              <td class="px-6 py-4 text-sm text-stone-500 font-mono"><%= category.id %></td>
              <td class="px-6 py-4 text-sm font-semibold text-stone-900"><%= category.nombre %></td>
              <td class="px-6 py-4 text-sm text-stone-600 truncate max-w-xs"><%= category.descripcion %></td>
              <td class="px-6 py-4 text-center">
                <span class="inline-flex items-center justify-center min-w-[2rem] px-2 py-0.5 rounded-md text-xs font-bold bg-stone-100 text-stone-700">
                  <%= category.productos.count %>
                </span>
              </td>
              <td class="px-6 py-4 text-right space-x-2">
                <%= link_to 'Ver', category_path(category), class: "inline-flex items-center text-sm font-medium text-stone-600 hover:text-stone-900 hover:underline" %>
                <span class="text-stone-300">|</span>
                <% if current_user.administrador? || current_user.encargado? %>
                  <%= link_to 'Editar', edit_category_path(category), class: "inline-flex items-center text-sm font-medium text-amber-600 hover:text-amber-800 hover:underline" %>
                  <span class="text-stone-300">|</span>
                  <button type="button" onclick="document.getElementById('modal-eliminar-cat-<%= category.id %>').classList.remove('hidden')"
                          class="inline-flex items-center text-sm font-medium text-red-600 hover:text-red-800 hover:underline">
                    Eliminar
                  </button>
                  <div id="modal-eliminar-cat-<%= category.id %>" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
                    <div class="absolute inset-0 bg-stone-900/50 backdrop-blur-sm"
                         onclick="document.getElementById('modal-eliminar-cat-<%= category.id %>').classList.add('hidden')"></div>
                    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-sm p-6 space-y-4">
                      <h2 class="text-lg font-bold text-stone-900">¿Eliminar categoría?</h2>
                      <p class="text-sm text-stone-500">Esta acción no se puede deshacer. La categoría <strong><%= category.nombre %></strong> será eliminada permanentemente.</p>
                      <div class="flex justify-end gap-3 pt-2">
                        <button type="button"
                                onclick="document.getElementById('modal-eliminar-cat-<%= category.id %>').classList.add('hidden')"
                                class="px-4 py-2 text-sm font-semibold text-stone-700 bg-white border border-stone-200 rounded-xl hover:bg-stone-50">
                          Cancelar
                        </button>
                        <%= button_to "Eliminar", category_path(category),
                            method: :delete,
                            form: { class: "inline" },
                            class: "px-4 py-2 text-sm font-semibold text-white bg-red-600 hover:bg-red-700 rounded-xl cursor-pointer" %>
                      </div>
                    </div>
                  </div>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @categories.empty? %>
            <tr>
              <td colspan="5" class="px-6 py-12 text-center text-stone-500 text-sm">
                <div class="flex flex-col items-center justify-center">
                  <svg class="w-10 h-10 text-stone-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                  <p class="text-base font-medium text-stone-900">No hay categorías</p>
                  <p class="mt-1">Crea una nueva categoría para organizar los productos.</p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

</div>
