<div class="max-w-4xl mx-auto space-y-6">

  <!-- Header & Acciones -->
  <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
    <div class="flex items-start gap-4">
      <%= link_to productos_path, class: "p-2 text-stone-400 hover:text-stone-600 bg-white border border-stone-200 rounded-xl hover:bg-stone-50 transition-colors mt-1" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      <% end %>
      <div>
        <div class="flex items-center gap-3 mb-1">
          <h1 class="text-3xl font-bold text-stone-900 tracking-tight"><%= @producto.nombre %></h1>
          <% if @producto.bajo_stock? %>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-bold bg-red-100 text-red-800 ring-1 ring-red-200">
              <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
              Bajo stock
            </span>
          <% else %>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-bold bg-emerald-100 text-emerald-800 ring-1 ring-emerald-200">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
              OK
            </span>
          <% end %>
        </div>
        <p class="text-sm text-stone-500 font-mono">ID: <%= @producto.id %></p>
      </div>
    </div>

    <div class="flex items-center gap-2">
      <% if current_user.administrador? || current_user.encargado? %>
        <%= link_to edit_producto_path(@producto), class: "inline-flex items-center justify-center gap-2 px-4 py-2 bg-amber-50 hover:bg-amber-100 border border-amber-200 text-amber-700 text-sm font-semibold rounded-xl transition-colors focus:outline-none focus:ring-2 focus:ring-amber-500 focus:ring-offset-2" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
          Editar
        <% end %>
      <% end %>

      <% if current_user.administrador? %>
        <button type="button"
                onclick="document.getElementById('modal-eliminar').classList.remove('hidden')"
                class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-white hover:bg-red-50 border border-stone-200 hover:border-red-200 text-red-600 text-sm font-semibold rounded-xl transition-colors focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
          Eliminar
        </button>
      <% end %>
    </div>
  </div>

  <!-- Contenido Principal -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Detalles del Producto -->
    <div class="md:col-span-2 bg-white rounded-2xl shadow-sm border border-stone-200 overflow-hidden">
      <div class="px-6 py-5 border-b border-stone-100 bg-stone-50/50">
        <h3 class="text-base font-semibold text-stone-900">Información General</h3>
      </div>
      <div class="px-6 py-5">
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-6">
          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-stone-500">Categoría</dt>
            <dd class="mt-1 text-sm text-stone-900">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-stone-100 text-stone-700 ring-1 ring-inset ring-stone-500/10">
                <%= @producto.category&.nombre || "Sin Categoría" %>
              </span>
            </dd>
          </div>

          <div class="sm:col-span-1">
            <dt class="text-sm font-medium text-stone-500">Unidad de Medida</dt>
            <dd class="mt-1 text-sm text-stone-900 capitalize"><%= @producto.unidad || "No especificada" %></dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Panel de Stock -->
    <div class="bg-white rounded-2xl shadow-sm border <%= @producto.bajo_stock? ? 'border-red-200' : 'border-stone-200' %> overflow-hidden relative">
      <% if @producto.bajo_stock? %>
        <div class="absolute top-0 right-0 w-24 h-24 bg-red-50 rounded-full -mr-8 -mt-8"></div>
      <% end %>

      <div class="px-6 py-5 border-b <%= @producto.bajo_stock? ? 'border-red-100 bg-red-50/30' : 'border-stone-100 bg-stone-50/50' %> relative">
        <h3 class="text-base font-semibold <%= @producto.bajo_stock? ? 'text-red-900' : 'text-stone-900' %>">Estado de Stock</h3>
      </div>

      <div class="px-6 py-6 relative">
        <div class="flex items-baseline gap-2 mb-4">
          <p class="text-5xl font-extrabold <%= @producto.bajo_stock? ? 'text-red-700' : 'text-stone-900' %>"><%= @producto.cantidad %></p>
          <span class="text-sm font-medium <%= @producto.bajo_stock? ? 'text-red-600' : 'text-stone-500' %>"><%= @producto.unidad %></span>
        </div>

        <div class="mt-4 pt-4 border-t border-stone-100">
          <div class="flex justify-between items-center text-sm">
            <span class="text-stone-500">Stock Mínimo Requerido</span>
            <span class="font-semibold text-stone-900"><%= @producto.stock_minimo %></span>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- Modal de confirmación -->
<% if current_user.administrador? %>
<div id="modal-eliminar" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
  <div class="absolute inset-0 bg-stone-900/50 backdrop-blur-sm"
       onclick="document.getElementById('modal-eliminar').classList.add('hidden')"></div>
  <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-sm p-6 space-y-4">
    <h2 class="text-lg font-bold text-stone-900">¿Eliminar producto?</h2>
    <p class="text-sm text-stone-500">Esta acción no se puede deshacer. El producto será eliminado permanentemente del inventario.</p>
    <div class="flex justify-end gap-3 pt-2">
      <button type="button"
              onclick="document.getElementById('modal-eliminar').classList.add('hidden')"
              class="px-4 py-2 text-sm font-semibold text-stone-700 bg-white border border-stone-200 rounded-xl hover:bg-stone-50">
        Cancelar
      </button>
      <%= button_to "Eliminar", @producto,
          method: :delete,
          form: { class: "inline" },
          class: "px-4 py-2 text-sm font-semibold text-white bg-red-600 hover:bg-red-700 rounded-xl cursor-pointer" %>
    </div>
  </div>
</div>
<% end %>
