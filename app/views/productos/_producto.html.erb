<div id="<%= dom_id producto %>">
  <p>
    <strong>Nombre:</strong>
    <%= producto.nombre %>
  </p>

  <p>
    <strong>Categoria:</strong>
    <%= producto.categoria %>
  </p>

  <p>
    <strong>Cantidad:</strong>
    <%= producto.cantidad %>
  </p>

  <p>
    <strong>Unidad:</strong>
    <%= producto.unidad %>
  </p>

</div>
