<%= form_with(model: producto, local: true, html: { class: "mx-auto mt-4 p-3 border rounded shadow-sm bg-white", style: "max-width: 600px;" }) do |form| %>
  <% if producto.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(producto.errors.count, "error") %> impiden guardar este producto:</h4>
      <ul>
        <% producto.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <h4 class="text-center mb-3 text-danger fw-bold">Nuevo Producto</h4>

  <div class="mb-3">
    <%= form.label :nombre, class: "form-label fw-semibold" %>
    <%= form.text_field :nombre, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :categoria, class: "form-label fw-semibold" %>
    <%= form.text_field :categoria, class: "form-control" %>
  </div>

  <div class="row mb-3">
    <div class="col-md-4">
      <%= form.label :cantidad, class: "form-label fw-semibold" %>
      <%= form.number_field :cantidad, class: "form-control" %>
    </div>

    <div class="col-md-4">
      <%= form.label :stock_minimo, "Stock mínimo", class: "form-label fw-semibold" %>
      <%= form.number_field :stock_minimo, class: "form-control" %>
    </div>

    <div class="col-md-4">
      <%= form.label :unidad, "Unidad", class: "form-label fw-semibold" %>
      <%= form.select :unidad,
          options_for_select([
            ['Unidad', 'unidad'],
            ['Kg', 'kg'],
            ['L', 'l'],
            ['Caja', 'caja']
          ], producto.unidad),
          { prompt: "Seleccionar unidad" },
          class: "form-select" %>
    </div>
  </div>

  <div class="text-center mt-3">
    <%= form.submit "Guardar Producto", class: "btn btn-danger px-4 fw-semibold" %>
  </div>
<% end %>

<div class="mt-3 text-center">
  <%= link_to "Volver a productos", productos_path, class: "btn btn-outline-danger btn-sm" %>
</div>
