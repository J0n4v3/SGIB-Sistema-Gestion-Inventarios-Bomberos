<%= form_with(model: producto, local: true, class: "space-y-6") do |form| %>
  <% if producto.errors.any? %>
    <div class="rounded-xl border border-red-200 bg-red-50 p-4 shadow-sm mb-6">
      <h4 class="text-sm font-bold text-red-800"><%= pluralize(producto.errors.count, "error") %> impiden guardar este producto:</h4>
      <ul class="mt-2 list-disc list-inside text-sm text-red-700">
        <% producto.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-2xl shadow-sm border border-stone-200 p-6 md:p-8">
    <div class="space-y-6">
      <div>
        <%= form.label :nombre, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= form.text_field :nombre, class: "block w-full rounded-xl border border-stone-300 shadow-sm focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500/50 sm:text-sm px-4 py-2.5 bg-white text-stone-900 transition-colors" %>
      </div>

      <div>
        <%= form.label :category_id, "Categoría", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= form.collection_select :category_id, Category.all, :id, :nombre,
              { prompt: "Seleccione una categoría" },
              { class: "block w-full rounded-xl border border-stone-300 shadow-sm focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500/50 sm:text-sm px-4 py-2.5 bg-white text-stone-900 transition-colors" } %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <%= form.label :cantidad, class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= form.number_field :cantidad, class: "block w-full rounded-xl border border-stone-300 shadow-sm focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500/50 sm:text-sm px-4 py-2.5 bg-white text-stone-900 transition-colors" %>
        </div>

        <div>
          <%= form.label :stock_minimo, "Stock mínimo", class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= form.number_field :stock_minimo, class: "block w-full rounded-xl border border-stone-300 shadow-sm focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500/50 sm:text-sm px-4 py-2.5 bg-white text-stone-900 transition-colors" %>
        </div>

        <div>
          <%= form.label :unidad, "Unidad", class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= form.select :unidad,
              options_for_select([['Unidad', 'unidad'], ['Kg', 'kg'], ['L', 'l'], ['Caja', 'caja']], producto.unidad),
              { prompt: "Seleccionar unidad" },
              class: "block w-full rounded-xl border border-stone-300 shadow-sm focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500/50 sm:text-sm px-4 py-2.5 bg-white text-stone-900 transition-colors" %>
        </div>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3 pt-2">
    <%= link_to "Cancelar", productos_path, class: "px-4 py-2.5 text-sm font-medium text-stone-600 bg-white border border-stone-200 rounded-xl hover:bg-stone-50 hover:text-stone-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-stone-500 transition-colors" %>
    <%= form.submit "Guardar Producto", class: "px-6 py-2.5 bg-red-700 hover:bg-red-800 text-white text-sm font-semibold rounded-xl shadow-sm shadow-red-700/20 focus:outline-none focus:ring-2 focus:ring-red-600 focus:ring-offset-2 transition-all cursor-pointer" %>
  </div>
<% end %>