<div class="d-flex justify-content-center align-items-center vh-100 bg-light">
  <div class="card shadow p-4" style="width: 100%; max-width: 400px;">
    <div class="text-center mb-4">
      <h2 class="text-danger fw-bold">Registrarse</h2>
      <p class="text-muted">Crear una cuenta para acceder al sistema de inventario</p>
    </div>

    <%= form_for(resource, as: resource_name, url: user_registration_path) do |f| %>

      <% if resource.errors.any? %>
        <div class="alert alert-danger">
          <h6 class="fw-bold"><%= pluralize(resource.errors.count, "error") %> impiden guardar la cuenta:</h6>
          <ul class="mb-0">
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.email_field :email, autofocus: true, class: "form-control", placeholder: "Correo electrónico" %>
      </div>

      <div class="mb-3">
        <%= f.password_field :password, autocomplete: "new-password", class: "form-control", placeholder: "Contraseña" %>
        <% if @minimum_password_length %>
          <small class="text-muted">Mínimo <%= @minimum_password_length %> caracteres</small>
        <% end %>
      </div>

      <div class="mb-3">
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", placeholder: "Confirmar contraseña" %>
      </div>

      <div class="d-grid mb-3">
        <%= f.submit "Registrarse", class: "btn btn-danger fw-bold" %>
      </div>
    <% end %>

    <div class="text-center">
      <%= link_to "¿Ya tenés una cuenta? Iniciar sesión", new_user_session_path, class: "text-decoration-none text-secondary" %>
    </div>
  </div>
</div>
