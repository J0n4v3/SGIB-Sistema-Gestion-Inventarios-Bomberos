<div class="d-flex justify-content-center align-items-center vh-100 bg-light">
  <div class="card shadow p-4" style="width: 100%; max-width: 400px;">
    <div class="text-center mb-4">
      <h2 class="text-danger fw-bold">🚒 Iniciar Sesión</h2>
      <p class="text-muted">Accedé al sistema de inventario</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-3">
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, autofocus: true, class: "form-control", placeholder: "usuario@ejemplo.com" %>
      </div>

      <div class="mb-3">
        <%= f.label :password, class: "form-label" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "form-control", placeholder: "••••••••" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-check mb-3">
          <%= f.check_box :remember_me, class: "form-check-input" %>
          <%= f.label :remember_me, class: "form-check-label" %>
        </div>
      <% end %>

      <div class="d-grid mb-3">
        <%= f.submit "Ingresar", class: "btn btn-danger fw-bold" %>
      </div>
    <% end %>

    <div class="text-center">
      <%= link_to "¿Olvidaste tu contraseña?", new_password_path(resource_name), class: "text-decoration-none text-secondary" %><br>
      <%= link_to "Registrarse", new_registration_path(resource_name), class: "text-decoration-none text-secondary" %>
    </div>
  </div>
</div>
