<div class="login-bg min-vh-100 d-flex justify-content-center align-items-center w-100  ">
  <div class="absolute inset-0 z-0">
    <%= image_tag "firetruck.jpg", class: "max w-full h-full object-cover" %>
    <div class="absolute inset-0 bg-stone-900/60 backdrop-blur-[2px]"></div>
  </div>

  <div class="relative z-10 bg-white p-8 rounded-2xl shadow-2xl w-full max-w-md border border-white/20">
    <% if flash[:alert] %>
  <div class="mb-4 p-3 bg-red-100 border border-red-400 text-red-700 rounded-xl text-center text-sm">
    <%= flash[:alert] %>
  </div>
<% end %>
    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold text-red-600">Iniciar Sesión</h2>
      <p class="text-stone-500 mt-2">Accedé al sistema de inventario</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { data: { turbo: false } }) do |f| %>
      <div class="mb-5">
        <%= f.text_field :username, autofocus: true,
            class: "w-full px-4 py-2.5 rounded-xl border border-stone-300 focus:outline-none focus:ring-2 focus:ring-red-500/50 focus:border-red-500 transition-colors text-stone-900 bg-white placeholder:text-stone-400", 
            placeholder: "Usuario" %>
      </div>

      <div class="mb-6">
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full px-4 py-2.5 rounded-xl border border-stone-300 focus:outline-none focus:ring-2 focus:ring-red-500/50 focus:border-red-500 transition-colors text-stone-900 bg-white placeholder:text-stone-400", 
            placeholder: "Contraseña" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center mb-6">
          <%= f.check_box :remember_me, class: "w-4 h-4 text-red-600 border-stone-300 rounded focus:ring-red-500 cursor-pointer" %>
          <%= f.label :remember_me, "Mantener sesión activa", class: "ml-2 text-sm text-stone-600 cursor-pointer" %>
        </div>
      <% end %>

      <div class="mt-2">
        <%= f.submit "Ingresar", 
            class: "w-full py-2.5 bg-red-600 hover:bg-red-700 text-white font-bold rounded-xl shadow-sm focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>