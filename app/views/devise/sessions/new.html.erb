<div class="login-bg min-vh-100 d-flex justify-content-center align-items-center w-100">

  <div class="login-card">

    <div class="text-center mb-4">
      <h2 class="text-danger fw-bold">Iniciar Sesión</h2>
      <p class="text-muted">Accedé al sistema de inventario</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="mb-3">
        <%= f.email_field :email, autofocus: true,
            class: "form-control", placeholder: "Usuario o Correo" %>
      </div>

      <div class="mb-3">
        <%= f.password_field :password, autocomplete: "current-password",
            class: "form-control", placeholder: "Contraseña" %>
      </div>

      <div class="d-grid mb-3">
        <%= f.submit "Ingresar", class: "btn btn-danger fw-bold" %>
      </div>

    <% end %>

    <div class="text-center">
      <%#= link_to "¿Olvidaste tu contraseña?",
          new_password_path(resource_name),
          class: "text-decoration-none text-secondary d-block mb-2" %>
    </div>

  </div>

</div>
