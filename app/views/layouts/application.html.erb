<!DOCTYPE html>
<html>
  <head>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <title><%= content_for(:title) || "Aw Inventario Bomberos" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

  </head>

  <body>

<% if user_signed_in? %>

  <!-- LAYOUT PARA USUARIOS LOGUEADOS -->
  <div class="d-flex">

    <!-- SIDEBAR -->
    <nav id="sidebar" class="bg-dark text-white p-3" style="width: 240px; min-height: 100vh;">
      <h4 class="text-center mb-4">🚒 Inventario</h4>

      <ul class="nav flex-column">

        <li class="nav-item mb-2">
          <%= link_to "Productos", productos_path, class: "nav-link text-white" %>
        </li>

        <li class="nav-item mb-2">
          <%= link_to "Movimientos", movimientos_path, class: "nav-link text-white" %>
        </li>
        <li class="nav-item mb-2">
          <%= link_to "Mantenimientos", mantenimientos_path, class: "nav-link text-white" %>
        </li>

        <% if current_user.admin? || current_user.encargado? %>
          <li class="nav-item mb-2">
            <%= link_to "Usuarios", usuarios_path, class: "nav-link text-white" %>
          </li>
        <% end %>

        <% if current_user.admin? %>
          <li class="nav-item mb-2">
            <%= link_to "Ajustes de Inventario", ajustes_path, class: "nav-link text-white" %>

          </li>
        <% end %>

      </ul>
    </nav>


    <!-- CONTENEDOR PRINCIPAL -->
    <div class="flex-grow-1">

      <!-- NAVBAR SUPERIOR -->
      <nav class="navbar navbar-light bg-white border-bottom shadow-sm px-4 d-flex justify-content-between">

        <!-- Botón toggle SOLO móvil -->
        <button id="sidebarToggle" class="btn btn-outline-danger d-md-none">
          ☰
        </button>

        <div class="ms-auto d-flex align-items-center">
          <span class="me-3 fw-bold">
            👤 <%= current_user.email %> — <%= current_user.role.humanize %>
          </span>

          <button type="button" class="btn btn-danger btn-sm"
                  data-bs-toggle="modal" data-bs-target="#logoutModal">
            Cerrar sesión
          </button>
        </div>

      </nav>

      <!-- CONTENIDO -->
      <main class="p-4" style="background-color: #f5f5f5; min-height: 100vh;">

        <% if notice %>
          <div class="alert alert-success"><%= notice %></div>
        <% end %>

        <% if alert %>
          <div class="alert alert-danger"><%= alert %></div>
        <% end %>

        <%= yield %>

      </main>

    </div>

  </div>


  <!-- MODAL DE CIERRE -->
  <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header bg-danger text-white">
          <h5 class="modal-title" id="logoutModalLabel">Confirmar cierre de sesión</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">¿Está seguro que desea cerrar sesión?</div>
        <div class="modal-footer">
          <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <%= button_to "Cerrar sesión", destroy_user_session_path, method: :delete, class: "btn btn-danger" %>
        </div>
      </div>
    </div>
  </div>

<% else %>

  <!-- LOGIN SIN SIDEBAR NI NAVBAR -->
  <div class="login-bg vh-100 d-flex justify-content-center align-items-center" style="width: 100%;">
    <%= yield %>
  </div>

<% end %>


<!-- Bootstrap -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>
