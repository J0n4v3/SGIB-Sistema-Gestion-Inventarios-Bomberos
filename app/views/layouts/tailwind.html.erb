<!DOCTYPE html>
<html lang="es">
  <head>
    <title><%= content_for(:title) || "Aw Inventario Bomberos" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Tailwind CSS (CDN for experiment) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 text-slate-900 font-sans antialiased">
    <% if user_signed_in? %>
      <div class="flex h-screen overflow-hidden">
        
        <!-- SIDEBAR -->
        <nav class="w-64 bg-neutral-950 text-white flex flex-col transition-all duration-300 shadow-xl hidden md:flex border-r border-red-900/30">
          <div class="p-6">
            <h4 class="text-xl font-bold flex items-center gap-3 text-red-500">
              <span class="text-2xl">🚒</span> Inventario
            </h4>
          </div>

          <ul class="flex flex-col gap-2 px-4 py-2 flex-grow">
            <li>
              <%= link_to dashboard_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl transition-all #{current_page?(dashboard_path) ? 'bg-red-700 text-white shadow-lg shadow-red-600/30 font-semibold border-l-4 border-amber-400' : 'text-neutral-400 hover:bg-neutral-900 hover:text-white'}" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                Inicio
              <% end %>
            </li>
            <li>
              <%= link_to productos_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl transition-all #{current_page?(productos_path) ? 'bg-red-700 text-white shadow-lg shadow-red-600/30 font-semibold border-l-4 border-amber-400' : 'text-neutral-400 hover:bg-neutral-900 hover:text-white'}" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
                Productos
              <% end %>
            </li>
            <% if current_user.administrador? || current_user.supervisor? %>
              <li>
                <%= link_to categories_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl transition-all #{current_page?(categories_path) ? 'bg-red-700 text-white shadow-lg shadow-red-600/30 font-semibold border-l-4 border-amber-400' : 'text-neutral-400 hover:bg-neutral-900 hover:text-white'}" do %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                  Categorías
                <% end %>
              </li>
            <% end %>
            <li>
              <%= link_to movimientos_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl transition-all #{current_page?(movimientos_path) ? 'bg-red-700 text-white shadow-lg shadow-red-600/30 font-semibold border-l-4 border-amber-400' : 'text-neutral-400 hover:bg-neutral-900 hover:text-white'}" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path></svg>
                Movimientos
              <% end %>
            </li>
            <li>
              <%= link_to mantenimientos_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl transition-all #{current_page?(mantenimientos_path) ? 'bg-red-700 text-white shadow-lg shadow-red-600/30 font-semibold border-l-4 border-amber-400' : 'text-neutral-400 hover:bg-neutral-900 hover:text-white'}" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                Mantenimientos
              <% end %>
            </li>
            
            <% if current_user.administrador? %>
              <li>
                <%= link_to usuarios_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl transition-all #{current_page?(usuarios_path) ? 'bg-red-700 text-white shadow-lg shadow-red-600/30 font-semibold border-l-4 border-amber-400' : 'text-neutral-400 hover:bg-neutral-900 hover:text-white'}" do %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                  Usuarios
                <% end %>
              </li>
            <% end %>

            <% if current_user.administrador? || current_user.supervisor? %>
              <li>
                <%= link_to ajustes_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl transition-all #{current_page?(ajustes_path) ? 'bg-red-700 text-white shadow-lg shadow-red-600/30 font-semibold border-l-4 border-amber-400' : 'text-neutral-400 hover:bg-neutral-900 hover:text-white'}" do %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
                  Ajustes de Inventario
                <% end %>
              </li>
            <% end %>
          </ul>
        </nav>

        <!-- MAIN CONTENT -->
        <div class="flex-1 flex flex-col h-screen overflow-hidden bg-stone-50">
          
          <!-- TOP NAVBAR -->
          <header class="h-20 bg-white border-b border-slate-200 shadow-sm flex items-center justify-between px-8 z-10">
            <!-- Botón toggle móvil -->
            <button class="md:hidden p-2 text-slate-500 hover:bg-slate-100 rounded-lg">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
            </button>
            
            <div class="ml-auto flex items-center gap-6">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center text-red-700 font-bold border border-red-200">
                  <%= current_user.email[0].upcase %>
                </div>
                <div class="hidden sm:block">
                  <p class="text-sm font-semibold text-slate-800"><%= current_user.email %></p>
                  <p class="text-xs text-slate-500 capitalize"><%= current_user.role %></p>
                </div>
              </div>
              
              <div class="h-8 w-px bg-slate-200"></div>

              <%= button_to destroy_user_session_path, method: :delete, class: "flex items-center gap-2 px-4 py-2 bg-red-50 text-red-600 hover:bg-red-100 rounded-lg font-medium transition-colors text-sm" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                Salir
              <% end %>
            </div>
          </header>

          <!-- PAGE CONTENT -->
          <main class="flex-1 overflow-y-auto p-8">
            <% if notice %>
              <div class="mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-800 flex items-center gap-3 shadow-sm">
                <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <p class="font-medium"><%= notice %></p>
              </div>
            <% end %>

            <% if alert %>
              <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-200 text-red-800 flex items-center gap-3 shadow-sm">
                <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <p class="font-medium"><%= alert %></p>
              </div>
            <% end %>

            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <!-- LOGIN -->
      <div class="min-h-screen bg-slate-100 flex items-center justify-center p-4">
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
