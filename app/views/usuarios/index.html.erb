<% content_for :title, "Usuarios" %>
<div class="max-w-7xl mx-auto space-y-6" data-controller="modal">
  <div data-modal-target="modal" class="<%= 'hidden' unless @usuario&.errors&.any? %> fixed inset-0 z-50 flex items-center justify-center bg-black/50">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md mx-4 p-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-stone-900">Nuevo Usuario</h2>
        <button data-action="click->modal#close" class="text-stone-400 hover:text-stone-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <%= form_with model: @usuario, url: usuarios_path, method: :post, local: true, class: "space-y-4" do |f| %>
        <% if @usuario&.errors&.any? %>
          <div class="p-3 rounded-xl bg-red-50 border border-red-200 text-red-800 text-xs">
            <ul class="list-disc pl-4 space-y-0.5">
              <% @usuario.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :username, "Usuario", class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= f.text_field :username, class: "w-full rounded-lg border border-stone-300 shadow-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/50 sm:text-sm px-4 py-2.5 bg-white text-stone-900 transition-colors", placeholder: "nombre_usuario" %>
        </div>
        <div>
          <%= f.label :password, "Contraseña", class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= f.password_field :password, class: "w-full rounded-lg border border-stone-300 shadow-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/50 sm:text-sm px-4 py-2.5 bg-white text-stone-900 transition-colors" %>
        </div>
        <div>
          <%= f.label :password_confirmation, "Confirmar contraseña", class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= f.password_field :password_confirmation, class: "w-full rounded-lg border border-stone-300 shadow-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/50 sm:text-sm px-4 py-2.5 bg-white text-stone-900 transition-colors" %>
        </div>
        <div>
          <%= f.label :role, "Rol", class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= f.select :role, User.roles.keys.map { |r| [r.humanize, r] }, {}, class: "w-full rounded-lg border border-stone-300 shadow-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/50 sm:text-sm px-4 py-2.5 bg-white text-stone-900 transition-colors" %>
        </div>
        <div class="flex justify-end gap-3 pt-2">
          <button type="button" data-action="click->modal#close" 
                  class="px-4 py-2 text-sm font-semibold text-stone-700 bg-white border border-stone-200 rounded-lg hover:bg-stone-50">
            Cancelar
          </button>
          <%= f.submit "Crear Usuario", class: "px-4 py-2 text-sm font-semibold text-white bg-red-600 hover:bg-red-700 rounded-lg cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-stone-900 tracking-tight pb-1">Gestión de Usuarios</h1>
      
      <p class="mt-1 text-sm text-stone-500">Administra los roles y accesos al sistema.</p>
    </div>
    <button data-action="click->modal#open" 
        class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-lg transition-colors">
  + Nuevo Usuario
</button>
  </div>



  <!-- Tabla de Usuarios -->
  <div class="bg-white rounded-2xl shadow-sm border border-stone-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-stone-50 text-stone-500 text-xs uppercase tracking-wider">
            <th class="px-6 py-4 font-bold border-b border-stone-200">Email</th>
            <th class="px-6 py-4 font-bold border-b border-stone-200 text-center">Rol Actual</th>
            <th class="px-6 py-4 font-bold border-b border-stone-200 text-right">Cambiar Rol</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-100">
          <% @usuarios.each do |usuario| %>
            <tr class="hover:bg-stone-50 transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-stone-200 flex items-center justify-center text-xs font-bold text-stone-600">
                    <%= usuario.username[0].upcase %>
                  </div>
                  <span class="text-sm font-semibold text-stone-900"><%= usuario.username %></span>
                </div>
              </td>
              
              <td class="px-6 py-4 text-center">
                <% case usuario.role %>
                <% when "administrador" %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-red-100 text-red-800 ring-1 ring-red-600/20">Admin</span>
                <% when "encargado" %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-amber-100 text-amber-800 ring-1 ring-amber-600/20">Encargado</span>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-stone-100 text-stone-700 ring-1 ring-stone-500/10">Bombero</span>
                <% end %>
              </td>

              <td class="px-6 py-4 text-right">
                <% if usuario == current_user %>
                  <span class="text-sm text-stone-400 italic px-2">No puedes modificarte a ti mismo</span>
                <% else %>
                  <%= form_with(model: usuario, url: usuario_path(usuario), method: :patch, local: true, class: "flex items-center justify-end gap-2") do |f| %>
                    <%= f.select :role, User.roles.keys.map { |r| [r.humanize, r] },
                                 {}, class: "block w-32 rounded-lg border-stone-200 shadow-sm focus:border-red-500 focus:ring-red-500 text-sm py-1.5 pl-3 pr-8 bg-white text-stone-700" %>
                    <%= f.submit "Actualizar", class: "px-3 py-1.5 bg-white hover:bg-red-50 border border-stone-200 hover:border-red-200 text-red-600 text-sm font-semibold rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-1 cursor-pointer" %>
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

</div>
