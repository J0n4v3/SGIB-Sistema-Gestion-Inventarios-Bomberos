<turbo-frame id="ultimos_movimientos">
  <div class="bg-white rounded-2xl shadow-sm border border-stone-200 overflow-hidden hover:border-red-300 transition-colors">
    <div class="p-6 border-b border-stone-100 flex items-center justify-between bg-stone-50/80">
      <div class="flex items-center gap-3">
        <div class="p-2 bg-red-50 rounded-lg">
          <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <h4 class="text-lg font-bold text-stone-800">Últimos Movimientos</h4>
      </div>
      
      <!-- Botón de recarga (simula actualización de la tabla vía Hotwire) -->
      <%= link_to dashboard_path, 
          class: "flex items-center gap-2 px-3 py-1.5 text-sm font-medium text-red-700 bg-red-50 hover:bg-red-100 rounded-lg transition-colors group",
          data: { turbo_frame: "ultimos_movimientos" } do %>
        <svg class="w-4 h-4 group-hover:rotate-180 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
        Actualizar
      <% end %>
    </div>
    
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-stone-50 text-stone-500 text-xs uppercase tracking-wider">
            <th class="px-6 py-4 font-medium border-b border-stone-200">Fecha</th>
            <th class="px-6 py-4 font-medium border-b border-stone-200">Producto</th>
            <th class="px-6 py-4 font-medium border-b border-stone-200">Tipo</th>
            <th class="px-6 py-4 font-medium border-b border-stone-200">Cant.</th>
            <th class="px-6 py-4 font-medium border-b border-stone-200">Usuario</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-100">
          <% @ultimos_movimientos.each do |movimiento| %>
            <tr class="hover:bg-stone-50/80 transition-colors">
              <td class="px-6 py-4 text-sm text-stone-600">
                <%= movimiento.created_at.strftime("%d/%m/%Y %H:%M") %>
              </td>
              <td class="px-6 py-4 text-sm font-medium text-stone-800">
                <%= movimiento.producto.nombre %>
              </td>
              <td class="px-6 py-4">
                <% if movimiento.tipo == "entrada" %>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12"></path></svg>
                    Entrada
                  </span>
                <% else %>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium bg-rose-50 text-rose-700 ring-1 ring-rose-600/20">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6"></path></svg>
                    Salida
                  </span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-sm font-bold text-stone-700">
                <%= movimiento.cantidad %>
              </td>
              <td class="px-6 py-4 text-sm text-stone-500">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded-full bg-stone-200 flex items-center justify-center text-[10px] font-bold text-stone-600">
                    <%= movimiento.user.username[0].upcase %>
                  </div>
                  <%= movimiento.user.username %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</turbo-frame>
