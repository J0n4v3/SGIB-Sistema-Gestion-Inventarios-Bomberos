<% content_for :title, "Panel de Control" %>

<div class="max-w-7xl mx-auto space-y-8" data-controller="dashboard">

  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-stone-900 pb-1">Panel de Control</h1>
      <p class="mt-1 text-sm text-stone-500">Resumen general del inventario y actividades recientes.</p>
    </div>
    
    <div class="flex items-center gap-3">
      <div class="px-4 py-2 bg-white border border-stone-200 rounded-xl shadow-sm text-sm font-medium text-stone-600 flex items-center gap-2">
        <svg class="w-4 h-4 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
        <span><%= Time.current.strftime("%d/%m/%Y") %></span>
      </div>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Stat Card 1 -->
    <div class="bg-white rounded-2xl p-6 shadow-sm border border-stone-200 hover:shadow-md hover:border-red-300 transition-all group relative overflow-hidden">
      <div class="absolute top-0 right-0 -mr-8 -mt-8 w-32 h-32 rounded-full bg-red-50 transition-transform group-hover:scale-110"></div>
      <div class="relative">
        <div class="w-12 h-12 bg-red-100 text-red-700 rounded-xl flex items-center justify-center mb-4 ring-4 ring-white shadow-sm">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
        </div>
        <h3 class="text-stone-500 text-sm font-medium">Stock Crítico</h3>
        <div class="mt-2 flex items-baseline gap-2">
          <p class="text-4xl font-extrabold text-stone-900"><%= @productos_criticos.count %></p>
          <span class="text-sm font-medium text-red-600">productos</span>
        </div>
      </div>
    </div>

    <!-- Stat Card 2 -->
    <div class="bg-white rounded-2xl p-6 shadow-sm border border-stone-200 hover:shadow-md hover:border-amber-300 transition-all group relative overflow-hidden">
      <div class="absolute top-0 right-0 -mr-8 -mt-8 w-32 h-32 rounded-full bg-amber-50 transition-transform group-hover:scale-110"></div>
      <div class="relative">
        <div class="w-12 h-12 bg-amber-100 text-amber-600 rounded-xl flex items-center justify-center mb-4 ring-4 ring-white shadow-sm">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
        </div>
        <h3 class="text-stone-500 text-sm font-medium">Mantenimientos</h3>
        <div class="mt-2 flex items-baseline gap-2">
          <p class="text-4xl font-extrabold text-stone-900"><%= @mantenimientos_pendientes.count %></p>
          <span class="text-sm font-medium text-amber-600">pendientes</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Alerta de Stock Crítico -->
  <% if @productos_criticos.any? %>
    <div class="rounded-xl border border-red-200 bg-red-50 p-4 shadow-sm" data-dashboard-target="alert">
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-500" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3 w-full">
          <h3 class="text-sm font-medium text-red-800">Atención requerida</h3>
          <div class="mt-2 text-sm text-red-700">
            <p>Hay <%= @productos_criticos.count %> productos con nivel de stock por debajo del mínimo establecido. Por favor, revisa el inventario.</p>
          </div>
        </div>
        <div class="ml-auto pl-3">
          <div class="-mx-1.5 -my-1.5">
            <button type="button" data-action="click->dashboard#dismissAlert" class="inline-flex rounded-md bg-red-50 p-1.5 text-red-500 hover:bg-red-100 focus:outline-none focus:ring-2 focus:ring-red-600 focus:ring-offset-2 focus:ring-offset-red-50">
              <span class="sr-only">Dismiss</span>
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Tabla Stock Crítico -->
    <div class="bg-white rounded-2xl shadow-sm border border-red-200 overflow-hidden ring-1 ring-red-50">
      <div class="p-6 border-b border-red-100 flex items-center gap-3 bg-red-50/30">
        <div class="p-2 bg-red-100 rounded-lg">
          <svg class="w-5 h-5 text-red-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
        </div>
        <h4 class="text-lg font-bold text-stone-800">Productos en Stock Crítico</h4>
      </div>
      
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-stone-50 text-stone-500 text-xs uppercase tracking-wider">
              <th class="px-6 py-4 font-medium border-b border-stone-200">Producto</th>
              <th class="px-6 py-4 font-medium border-b border-stone-200">Categoría</th>
              <th class="px-6 py-4 font-medium border-b border-stone-200 text-center">Stock Actual</th>
              <th class="px-6 py-4 font-medium border-b border-stone-200 text-center">Mínimo</th>
              <th class="px-6 py-4 font-medium border-b border-stone-200 text-right">Acción</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-stone-100">
            <% @productos_criticos.each do |producto| %>
              <tr class="hover:bg-red-50/50 transition-colors">
                <td class="px-6 py-4 text-sm font-semibold text-stone-800"><%= producto.nombre %></td>
                <td class="px-6 py-4">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700 ring-1 ring-inset ring-blue-700/10">
                    <%= producto.category&.nombre || "Sin Categoría" %>
                  </span>
                </td>
                <td class="px-6 py-4 text-center">
                  <span class="inline-flex items-center justify-center min-w-[2.5rem] px-2 py-1 rounded-md text-sm font-bold bg-red-100 text-red-700 ring-1 ring-red-200">
                    <%= producto.cantidad %>
                  </span>
                </td>
                <td class="px-6 py-4 text-center text-sm text-stone-500"><%= producto.stock_minimo %></td>
                <td class="px-6 py-4 text-right">
                  <%= link_to "Ver detalle", producto_path(producto), class: "text-sm font-medium text-red-600 hover:text-red-800 hover:underline" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 xl:grid-cols-2 gap-8">
    <!-- Últimos Movimientos (Turbo Frame) -->
    <%= render "movimientos" %>

    <!-- Mantenimientos Pendientes -->
    <div class="bg-white rounded-2xl shadow-sm border border-stone-200 overflow-hidden flex flex-col hover:border-amber-300 transition-colors">
      <div class="p-6 border-b border-stone-100 flex items-center gap-3 bg-stone-50/80">
        <div class="p-2 bg-amber-100 rounded-lg">
          <svg class="w-5 h-5 text-amber-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        </div>
        <h4 class="text-lg font-bold text-stone-800">Mantenimientos Pendientes</h4>
      </div>
      
      <div class="overflow-x-auto flex-1">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-stone-50 text-stone-500 text-xs uppercase tracking-wider">
              <th class="px-6 py-4 font-medium border-b border-stone-200">Producto</th>
              <th class="px-6 py-4 font-medium border-b border-stone-200">Fecha</th>
              <th class="px-6 py-4 font-medium border-b border-stone-200 text-right">Acción</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-stone-100">
            <% @mantenimientos_pendientes.each do |mantenimiento| %>
              <tr class="hover:bg-stone-50/80 transition-colors">
                <td class="px-6 py-4 text-sm font-medium text-stone-800">
                  <div class="flex flex-col gap-1">
                    <span><%= mantenimiento.producto.nombre %></span>
                    <span class="inline-flex w-fit px-2 py-0.5 rounded text-[10px] font-medium bg-stone-200 text-stone-700 uppercase tracking-wide">
                      <%= mantenimiento.tipo %>
                    </span>
                  </div>
                </td>
                <td class="px-6 py-4 text-sm text-stone-600">
                  <div class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    <%= mantenimiento.fecha_mantenimiento.strftime("%d/%m/%Y") %>
                  </div>
                  <% if mantenimiento.proximo_mantenimiento.present? %>
                    <p class="text-xs text-stone-400 mt-1">
                      Próx: <%= mantenimiento.proximo_mantenimiento.strftime("%d/%m/%Y") %>
                    </p>
                  <% end %>
                </td>
                <td class="px-6 py-4 text-right">
                  <%= link_to "Revisar", mantenimiento_path(mantenimiento), class: "inline-flex items-center justify-center px-3 py-1.5 border border-amber-200 text-sm font-medium rounded-lg text-amber-700 bg-amber-50 hover:bg-amber-100 transition-colors" %>
                </td>
              </tr>
            <% end %>
            <% if @mantenimientos_pendientes.empty? %>
              <tr>
                <td colspan="3" class="px-6 py-8 text-center text-stone-500 text-sm">
                  <div class="flex flex-col items-center justify-center">
                    <svg class="w-8 h-8 text-stone-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    No hay mantenimientos pendientes
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div>