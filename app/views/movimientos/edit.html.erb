<% content_for :title, "Editar Movimiento" %>

<div class="max-w-3xl mx-auto space-y-6">
  <div class="flex items-center gap-4">
    <%= link_to movimientos_path, class: "p-2 text-stone-400 hover:text-stone-600 bg-white border border-stone-200 rounded-xl hover:bg-stone-50 transition-colors" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
    <% end %>
    <div>
      <h1 class="text-2xl font-bold text-stone-900 tracking-tight">Editar Movimiento</h1>
      <p class="mt-1 text-sm text-stone-500">Modifica los detalles del movimiento #<%= @movimiento.id %>.</p>
    </div>
  </div>

  <%= render "form", movimiento: @movimiento %>
</div>
