<% content_for :title, "Detalle del Movimiento" %>

<div class="max-w-4xl mx-auto space-y-6">
  
  <!-- Header & Acciones -->
  <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
    <div class="flex items-start gap-4">
      <%= link_to movimientos_path, class: "p-2 text-stone-400 hover:text-stone-600 bg-white border border-stone-200 rounded-xl hover:bg-stone-50 transition-colors mt-1" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      <% end %>
      <div>
        <div class="flex items-center gap-3 mb-1">
          <h1 class="text-3xl font-bold text-stone-900 tracking-tight">Movimiento #<%= @movimiento.id %></h1>
          <% if @movimiento.tipo.to_s.strip.downcase == "entrada" %>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-bold bg-emerald-100 text-emerald-800 ring-1 ring-emerald-200 uppercase tracking-wide">
              Entrada
            </span>
          <% else %>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-bold bg-red-100 text-red-800 ring-1 ring-red-200 uppercase tracking-wide">
              Salida
            </span>
          <% end %>
        </div>
        <p class="text-sm text-stone-500 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          Registrado el <%= @movimiento.created_at.strftime("%d de %B, %Y a las %H:%M") %>
        </p>
      </div>
    </div>

    <div class="flex items-center gap-2">
      <%= link_to edit_movimiento_path(@movimiento), class: "inline-flex items-center justify-center gap-2 px-4 py-2 bg-amber-50 hover:bg-amber-100 border border-amber-200 text-amber-700 text-sm font-semibold rounded-xl transition-colors focus:outline-none focus:ring-2 focus:ring-amber-500 focus:ring-offset-2" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
        Editar
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Detalles del Producto -->
    <div class="bg-white rounded-2xl shadow-sm border border-stone-200 overflow-hidden">
      <div class="px-6 py-5 border-b border-stone-100 bg-stone-50/50">
        <h3 class="text-base font-semibold text-stone-900">Información del Producto</h3>
      </div>
      <div class="px-6 py-5">
        <dl class="space-y-4">
          <div>
            <dt class="text-sm font-medium text-stone-500">Producto</dt>
            <dd class="mt-1 text-base font-semibold text-stone-900 flex items-center justify-between">
              <%= @movimiento.producto.nombre %>
              <%= link_to "Ver producto", producto_path(@movimiento.producto), class: "text-sm font-normal text-red-600 hover:underline" %>
            </dd>
          </div>
          <div class="pt-4 border-t border-stone-100">
            <dt class="text-sm font-medium text-stone-500">Cantidad Alterada</dt>
            <dd class="mt-1 flex items-baseline gap-2">
              <span class="text-3xl font-extrabold <%= @movimiento.tipo.to_s.strip.downcase == 'entrada' ? 'text-emerald-700' : 'text-red-700' %>">
                <%= @movimiento.tipo.to_s.strip.downcase == 'entrada' ? '+' : '-' %><%= @movimiento.cantidad %>
              </span>
              <span class="text-sm font-medium text-stone-600"><%= @movimiento.producto.unidad %></span>
            </dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Detalles Administrativos -->
    <div class="bg-white rounded-2xl shadow-sm border border-stone-200 overflow-hidden">
      <div class="px-6 py-5 border-b border-stone-100 bg-stone-50/50">
        <h3 class="text-base font-semibold text-stone-900">Detalles Administrativos</h3>
      </div>
      <div class="px-6 py-5">
        <dl class="space-y-4">
          <div>
            <dt class="text-sm font-medium text-stone-500">Responsable</dt>
            <dd class="mt-1 text-sm font-medium text-stone-900 flex items-center gap-2">
              <div class="w-6 h-6 rounded-full bg-stone-200 flex items-center justify-center text-[10px] font-bold text-stone-700">
                <%= @movimiento.user.username[0].upcase %>
              </div>
              <%= @movimiento.user.username %>
            </dd>
          </div>
          <div class="pt-4 border-t border-stone-100">
            <dt class="text-sm font-medium text-stone-500">Motivo Frecuente</dt>
            <dd class="mt-1 text-sm text-stone-900">
              <span class="inline-flex px-2.5 py-0.5 rounded text-xs font-medium bg-stone-100 text-stone-700 border border-stone-200">
                <%= @movimiento.motivo_frecuente.presence || "No especificado" %>
              </span>
            </dd>
          </div>
          <% if @movimiento.otro_motivo.present? %>
            <div class="pt-4 border-t border-stone-100">
              <dt class="text-sm font-medium text-stone-500">Especificación (Otro motivo)</dt>
              <dd class="mt-1 text-sm text-stone-900 bg-stone-50 p-3 rounded-lg border border-stone-100">
                <%= @movimiento.otro_motivo %>
              </dd>
            </div>
          <% end %>
        </dl>
      </div>
    </div>
  </div>

</div>
