<%= form_with(model: movimiento, local: true, class: "space-y-6") do |form| %>
  
  <% if movimiento.errors.any? %>
    <div class="rounded-xl border border-red-200 bg-red-50 p-4 shadow-sm mb-6">
      <h4 class="text-sm font-bold text-red-800"><%= pluralize(movimiento.errors.count, "error") %> impiden guardar este movimiento:</h4>
      <ul class="mt-2 list-disc list-inside text-sm text-red-700">
        <% movimiento.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-2xl shadow-sm border border-stone-200 p-6 md:p-8">
    <div class="space-y-6">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Producto -->
        <div>
          <%= form.label :producto_id, "Producto", class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= form.collection_select :producto_id, Producto.all, :id, :nombre, { prompt: "Seleccione un producto" }, class: "block w-full rounded-xl border-stone-200 shadow-sm focus:border-red-500 focus:ring-red-500 sm:text-sm px-4 py-2.5 bg-stone-50 text-stone-900 transition-colors" %>
        </div>

        <!-- Tipo -->
        <div>
          <%= form.label :tipo, "Tipo", class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= form.select :tipo, [["Entrada", "entrada"], ["Salida", "salida"]], { prompt: "Seleccione tipo" }, class: "block w-full rounded-xl border-stone-200 shadow-sm focus:border-red-500 focus:ring-red-500 sm:text-sm px-4 py-2.5 bg-stone-50 text-stone-900 transition-colors" %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Cantidad -->
        <div>
          <%= form.label :cantidad, "Cantidad", class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= form.number_field :cantidad, min: 1, class: "block w-full rounded-xl border-stone-200 shadow-sm focus:border-red-500 focus:ring-red-500 sm:text-sm px-4 py-2.5 bg-stone-50 text-stone-900 transition-colors" %>
        </div>

        <!-- Responsable -->
        <div>
          <%= form.label :user_id, "Responsable", class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= form.collection_select :user_id, User.all, :id, :email, { prompt: "Seleccione responsable" }, class: "block w-full rounded-xl border-stone-200 shadow-sm focus:border-red-500 focus:ring-red-500 sm:text-sm px-4 py-2.5 bg-stone-50 text-stone-900 transition-colors" %>
        </div>
      </div>

      <!-- Motivo frecuente -->
      <div>
        <%= form.label :motivo_frecuente, "Motivo frecuente", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= form.select :motivo_frecuente, [
              ["Trabajo del día", "Trabajo del día"],
              ["Limpieza del pastizal", "Limpieza del pastizal"],
              ["Recarga de nuevo producto", "Recarga de nuevo producto"],
              ["Devolución de uso", "Devolución de uso"],
              ["Otros", "Otros"]
            ], { prompt: "Seleccione motivo" }, class: "block w-full rounded-xl border-stone-200 shadow-sm focus:border-red-500 focus:ring-red-500 sm:text-sm px-4 py-2.5 bg-stone-50 text-stone-900 transition-colors", id: "motivo_frecuente_select" %>
      </div>

      <!-- Otro motivo / descripción -->
      <div id="otro_motivo_div" style="display: none;">
        <%= form.label :otro_motivo, "Especificar motivo", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= form.text_area :otro_motivo, rows: 3, class: "block w-full rounded-xl border-stone-200 shadow-sm focus:border-red-500 focus:ring-red-500 sm:text-sm px-4 py-2.5 bg-stone-50 text-stone-900 transition-colors" %>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3 pt-2">
    <%= link_to "Cancelar", movimientos_path, class: "px-4 py-2.5 text-sm font-medium text-stone-600 bg-white border border-stone-200 rounded-xl hover:bg-stone-50 hover:text-stone-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-stone-500 transition-colors" %>
    <%= form.submit "Guardar Movimiento", class: "px-6 py-2.5 bg-red-700 hover:bg-red-800 text-white text-sm font-semibold rounded-xl shadow-sm shadow-red-700/20 focus:outline-none focus:ring-2 focus:ring-red-600 focus:ring-offset-2 transition-all cursor-pointer" %>
  </div>
<% end %>

<!-- JS para mostrar textarea si se selecciona "Otros" -->
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const select = document.getElementById("motivo_frecuente_select");
    const otroDiv = document.getElementById("otro_motivo_div");

    function checkMotivo() {
      if (select.value === "Otros") {
        otroDiv.style.display = "block";
      } else {
        otroDiv.style.display = "none";
      }
    }

    if (select) {
      select.addEventListener("change", checkMotivo);
      checkMotivo(); // on load
    }
  });
</script>
