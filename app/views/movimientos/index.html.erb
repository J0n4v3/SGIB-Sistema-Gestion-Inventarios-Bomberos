<% content_for :title, "Movimientos" %>

<div class="max-w-7xl mx-auto space-y-6">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-stone-900 tracking-tight pb-1">Listado de Movimientos</h1>
      <p class="mt-1 text-sm text-stone-500">Historial de entradas y salidas de inventario.</p>
    </div>
    
    <div>
      <%= link_to new_movimiento_path, class: "inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-red-700 hover:bg-red-800 text-white text-sm font-semibold rounded-xl shadow-sm shadow-red-700/20 transition-all focus:outline-none focus:ring-2 focus:ring-red-600 focus:ring-offset-2" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Nuevo Movimiento
      <% end %>
    </div>
  </div>



  <!-- Tabla de Movimientos -->
  <div class="bg-white rounded-2xl shadow-sm border border-stone-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-stone-50 text-stone-500 text-xs uppercase tracking-wider">
            <th class="px-6 py-4 font-medium border-b border-stone-200 w-16">ID</th>
            <th class="px-6 py-4 font-medium border-b border-stone-200">Fecha</th>
            <th class="px-6 py-4 font-medium border-b border-stone-200">Producto</th>
            <th class="px-6 py-4 font-medium border-b border-stone-200 text-center">Tipo</th>
            <th class="px-6 py-4 font-medium border-b border-stone-200 text-center">Cant.</th>
            <th class="px-6 py-4 font-medium border-b border-stone-200">Observación</th>
            <th class="px-6 py-4 font-medium border-b border-stone-200">Responsable</th>
            <th class="px-6 py-4 font-medium border-b border-stone-200 text-right">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-100">
          <% @movimientos.each do |movimiento| %>
            <% tipo = movimiento.tipo.to_s.strip.downcase %>
            <% is_entrada = (tipo == 'entrada') %>
            <tr class="hover:bg-stone-50 transition-colors">
              <td class="px-6 py-4 text-sm text-stone-500 font-mono"><%= movimiento.id %></td>
              <td class="px-6 py-4 text-sm text-stone-600"><%= movimiento.created_at.strftime("%d/%m/%Y %H:%M") %></td>
              <td class="px-6 py-4 text-sm font-semibold text-stone-900"><%= movimiento.producto.nombre %></td>
              <td class="px-6 py-4 text-center">
                <% if is_entrada %>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12"></path></svg>
                    Entrada
                  </span>
                <% else %>
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-xs font-medium bg-red-50 text-red-700 ring-1 ring-red-600/20">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6"></path></svg>
                    Salida
                  </span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-center">
                <span class="inline-flex items-center justify-center px-2 py-0.5 rounded-md text-sm font-bold <%= is_entrada ? 'text-emerald-700 bg-emerald-100' : 'text-red-700 bg-red-100' %>">
                  <%= is_entrada ? '+' : '-' %><%= movimiento.cantidad %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-stone-600 truncate max-w-xs" title="<%= movimiento.observacion %>">
                <%= movimiento.observacion.presence || "-" %>
              </td>
              <td class="px-6 py-4 text-sm text-stone-600">
                <%= movimiento.user.username || "Sin usuario" %>
              </td>
                
                            <td class="px-6 py-4 text-right space-x-2">
                <%= link_to 'Ver', movimiento_path(movimiento), class: "inline-flex items-center text-sm font-medium text-stone-600 hover:text-stone-900 hover:underline" %>
                
                <% if current_user.administrador? %>
                  
                  <% if false # Editar y Eliminar ocultos %>
                    <span class="text-stone-300">|</span>
                    <%= link_to 'Editar', edit_movimiento_path(movimiento), class: "inline-flex items-center text-sm font-medium text-amber-600 hover:text-amber-800 hover:underline" %>
                    
                    <span class="text-stone-300">|</span>
                    <button type="button" onclick="document.getElementById('modal-eliminar-mov-<%= movimiento.id %>').classList.remove('hidden')"
                            class="inline-flex items-center text-sm font-medium text-red-600 hover:text-red-800 hover:underline">
                    Eliminar
                    </button>
                    <div id="modal-eliminar-mov-<%= movimiento.id %>" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
                      <div class="absolute inset-0 bg-stone-900/50 backdrop-blur-sm"
                           onclick="document.getElementById('modal-eliminar-mov-<%= movimiento.id %>').classList.add('hidden')"></div>
                      <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-sm p-6 space-y-4">
                        <h2 class="text-lg font-bold text-stone-900">¿Eliminar movimiento?</h2>
                        <p class="text-sm text-stone-500">Esta acción no se puede deshacer. El movimiento será eliminado permanentemente del historial.</p>
                        <div class="flex justify-end gap-3 pt-2">
                          <button type="button"
                                  onclick="document.getElementById('modal-eliminar-mov-<%= movimiento.id %>').classList.add('hidden')"
                                  class="px-4 py-2 text-sm font-semibold text-stone-700 bg-white border border-stone-200 rounded-xl hover:bg-stone-50">
                            Cancelar
                          </button>
                          <%= button_to "Eliminar", movimiento_path(movimiento),
                              method: :delete,
                              form: { class: "inline" },
                              class: "px-4 py-2 text-sm font-semibold text-white bg-red-600 hover:bg-red-700 rounded-xl cursor-pointer" %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @movimientos.empty? %>
            <tr>
              <td colspan="7" class="px-6 py-12 text-center text-stone-500 text-sm">
                <div class="flex flex-col items-center justify-center">
                  <svg class="w-10 h-10 text-stone-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path></svg>
                  <p class="text-base font-medium text-stone-900">No hay movimientos</p>
                  <p class="mt-1">Aún no se han registrado entradas ni salidas de productos.</p>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

</div>
