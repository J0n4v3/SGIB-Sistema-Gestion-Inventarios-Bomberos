<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0">Historial de Mantenimientos</h1>

  <%= link_to "+ Registrar Mantenimiento", new_mantenimiento_path,
        class: "btn btn-danger fw-bold shadow-sm" %>
</div>

<table class="table table-bordered table-striped text-center">
  <thead class="table-warning">
    <tr>
      <th>Producto</th>
      <th>Tipo</th>
      <th>Fecha</th>
      <th>Próximo</th>
      <th>Estado</th>
      <th>Usuario</th>
    </tr>
  </thead>

  <tbody>
    <% @mantenimientos.each do |m| %>
      <tr>
        <td><%= m.producto.nombre %></td>
        <td><%= m.tipo %></td>
        <td><%= m.fecha_mantenimiento.strftime("%d/%m/%Y") %></td>
        <td><%= m.proximo_mantenimiento&.strftime("%d/%m/%Y") || "—" %></td>
        <td><%= m.estado_post_mantenimiento %></td>
        <td><%= m.user.email %></td>
      </tr>
    <% end %>
  </tbody>
</table>
